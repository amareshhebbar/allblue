<form version="1.1" theme="dark" refresh="60">
  <label>AllBlue — SOC &amp; DFIR Intelligence</label>
  <description>Autonomous multi-agent incident response and forensics orchestration powered by AllBlue + LLMs.</description>

  <fieldset submitButton="false" autoRun="true">
    <input type="time" token="global_time" searchWhenChanged="true">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
  </fieldset>

  <row>
    <panel>
      <title>Total IOCs Extracted</title>
      <single>
        <search>
          <query>index=main sourcetype="allblue:ioc" | stats count</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">none</option>
        <option name="showSparkline">1</option>
        <option name="showTrendIndicator">1</option>
        <option name="trendColorInterpretation">standard</option>
      </single>
    </panel>

    <panel>
      <title>Critical Severity IOCs</title>
      <single>
        <search>
          <query>index=main sourcetype="allblue:ioc" severity=CRITICAL | stats count</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <!-- Turns bright red if there is even 1 critical IOC -->
        <option name="colorMode">block</option>
        <option name="rangeColors">["0x53A051","0xDC4E41"]</option>
        <option name="rangeValues">[0]</option>
        <option name="useColors">1</option>
      </single>
    </panel>

    <panel>
      <title>Average Threat Score</title>
      <single>
        <search>
          <query>index=main sourcetype="allblue:summary" | stats avg(overall_threat_score) as avg_score | eval avg_score=round(avg_score, 1)</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="colorMode">none</option>
        <option name="numberPrecision">0.0</option>
        <option name="rangeColors">["0x53A051","0xF8BE34","0xDC4E41"]</option>
        <option name="rangeValues">[40,75]</option>
        <option name="useColors">1</option>
      </single>
    </panel>

    <panel>
      <title>Active Triage Sessions</title>
      <single>
        <search>
          <query>index=main sourcetype="allblue:summary" | stats dc(session_id)</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="colorMode">none</option>
        <option name="underLabel">Distinct Evidence Sources</option>
      </single>
    </panel>
  </row>

  <row>
    <panel>
      <title>Threat Timeline (by Severity)</title>
      <chart>
        <search>
          <query>index=main sourcetype="allblue:ioc" | timechart count by severity</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="charting.chart">column</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.legend.placement">bottom</option>
        <!-- Enforce strict coloring -->
        <option name="charting.fieldColors">{"CRITICAL": 0xDC4E41, "HIGH": 0xF8BE34, "MEDIUM": 0x0099E0, "LOW": 0x53A051}</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
      </chart>
    </panel>

    <panel>
      <title>IOC Distribution by Category</title>
      <chart>
        <search>
          <query>index=main sourcetype="allblue:ioc" | stats count by category | sort -count</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.axisTitleY.visibility">collapsed</option>
      </chart>
    </panel>

    <panel>
      <title>AI Confidence Ratio</title>
      <chart>
        <search>
          <query>index=main sourcetype="allblue:ioc" | stats count by confidence</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <!-- Pie charts look much better natively in Splunk than in standard UI -->
        <option name="charting.chart">pie</option>
        <option name="charting.fieldColors">{"CONFIRMED": 0x53A051, "INFERRED": 0xF8BE34, "UNVERIFIED": 0xDC4E41}</option>
      </chart>
    </panel>
  </row>

  <row>
    <panel>
      <title>AllBlue — Detailed IOC Extraction Table</title>
      <table>
        <search>
          <query>
            index=main sourcetype="allblue:ioc" 
            | eval Time=strftime(_time, "%Y-%m-%d %H:%M:%S")
            | rename session_id as "Session", severity as "Severity", category as "Category", ioc as "IOC", description as "Context/Description", confidence as "AI Confidence", threat_score as "Threat Score", tool as "SIFT Tool"
            | table Time, Session, Severity, Category, IOC, "Context/Description", "AI Confidence", "Threat Score", "SIFT Tool"
            | sort -"Threat Score"
          </query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">true</option>
        <format type="color" field="Severity">
          <colorPalette type="map">{"CRITICAL": #DC4E41, "HIGH": #F8BE34, "MEDIUM": #0099E0, "LOW": #53A051}</colorPalette>
        </format>
        <format type="color" field="AI Confidence">
          <colorPalette type="map">{"CONFIRMED": #53A051, "INFERRED": #F8BE34, "UNVERIFIED": #DC4E41}</colorPalette>
        </format>
        <format type="color" field="Threat Score">
          <colorPalette type="minMidMax" maxColor="#DC4E41" midColor="#F8BE34" minColor="#53A051"></colorPalette>
          <scale type="minMidMax" maxValue="100" midValue="50" minValue="0"></scale>
        </format>
      </table>
    </panel>
  </row>

  <row>
    <panel>
      <title>Triage Sessions Summary</title>
      <table>
        <search>
          <query>
            index=main sourcetype="allblue:summary" 
            | eval Time=strftime(_time, "%Y-%m-%d %H:%M:%S")
            | rename session_id as "Session ID", evidence_file as "Evidence Target", evidence_type as "Type", total_findings as "Total IOCs", critical_count as "Critical IOCs", overall_threat_score as "Overall Score", agent_engine as "LLM Engine", iterations as "Steps"
            | table Time, "Session ID", "Evidence Target", Type, "Total IOCs", "Critical IOCs", "Overall Score", "LLM Engine", Steps
            | sort -Time
          </query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <option name="rowNumbers">false</option>
        <format type="color" field="Overall Score">
          <colorPalette type="minMidMax" maxColor="#DC4E41" midColor="#292A2C" minColor="#292A2C"></colorPalette>
          <scale type="minMidMax" maxValue="80" midValue="50" minValue="0"></scale>
        </format>
      </table>
    </panel>

    <panel>
      <title>Live Agent Activity Console</title>
      <event>
        <search>
          <query>index=main sourcetype="allblue:log" | table _time, session_id, level, message | sort -_time</query>
          <earliest>$global_time.earliest$</earliest>
          <latest>$global_time.latest$</latest>
        </search>
        <option name="list.drilldown">none</option>
        <option name="maxLines">10</option>
        <option name="raw.drilldown">none</option>
        <option name="type">list</option>
      </event>
    </panel>
  </row>
</form>